<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>神経衰弱</title>
<style>
  body {
    margin: 0;
    background: #111;
    color: white;
    font-family: sans-serif;
    text-align: center;
  }

  h1 {
    font-size: 18px;
    margin: 10px 0;
  }

  #board {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    padding: 10px;
    max-width: 420px;
    margin: auto;
  }

  .card {
    aspect-ratio: 1;
    background: #333;
    border-radius: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24px;
    user-select: none;
  }

  .open {
    background: #eee;
    color: #111;
  }

  .joker {
    background: gold !important;
    color: black;
  }

  #message {
    margin: 10px;
    font-size: 16px;
  }
</style>
</head>
<body>

<h1>神経衰弱（ワンミス終了）</h1>
<div id="message">覚えろ…</div>
<div id="board"></div>

<script>
const chars = ["旺","旺","蒙","蒙","泰","泰","楓","楓","辛","辛","威","威","仔","仔","伍","伍","宋","宋","秋","秋"];
chars.push("傳"); // ジョーカー

// シャッフル
chars.sort(() => Math.random() - 0.5);

const board = document.getElementById("board");
const message = document.getElementById("message");

let first = null;
let second = null;
let lock = true;
let cleared = 0;

// カード生成
chars.forEach((value) => {
  const card = document.createElement("div");
  card.className = "card";
  card.dataset.value = value;
  card.textContent = value;
  board.appendChild(card);

  card.addEventListener("click", () => onClick(card));
});

// 初期2秒表示
setTimeout(() => {
  hideAll();
  lock = false;
  message.textContent = "スタート";
}, 2000);

// 全表示
function revealAll() {
  document.querySelectorAll(".card").forEach(c => {
    c.textContent = c.dataset.value;
    c.classList.add("open");
    if (c.dataset.value === "傳") c.classList.add("joker");
  });
}

// 非一致だけ伏せる
function hideUnmatched() {
  document.querySelectorAll(".card").forEach(c => {
    if (!c.classList.contains("matched") && c.dataset.value !== "傳") {
      c.textContent = "";
      c.classList.remove("open", "joker");
    }
  });
}

// 全伏せ
function hideAll() {
  document.querySelectorAll(".card").forEach(c => {
    if (c.dataset.value !== "傳") {
      c.textContent = "";
      c.classList.remove("open", "joker");
    }
  });
}

// クリック処理
function onClick(card) {
  if (lock || card.classList.contains("matched") || card === first) return;

  card.textContent = card.dataset.value;
  card.classList.add("open");

  // ジョーカー
  if (card.dataset.value === "傳") {
    lock = true;
    message.textContent = "ジョーカー！";

    revealAll();

    setTimeout(() => {
      hideUnmatched();
      lock = false;
      first = null;
      second = null;
      message.textContent = "続けろ…";
    }, 1000);
    return;
  }

  if (!first) {
    first = card;
  } else {
    second = card;
    lock = true;

    if (first.dataset.value === second.dataset.value) {
      first.classList.add("matched");
      second.classList.add("matched");

      cleared += 2;

      first = null;
      second = null;
      lock = false;

      // クリア判定（20枚）
      if (cleared === 20) {
        message.textContent = "クリア！";
      }

    } else {
      // ミス → 即ゲームオーバー
      message.textContent = "ゲームオーバー";
      setTimeout(() => {
        revealAll();
      }, 300);
    }
  }
}
</script>

</body>
</html>
